# =============================================================================
# 环境变量配置模板
# 复制此文件为 .env 并填入真实值：
# cp .env.example .env
# =============================================================================

# DeepSeek API Key（必填）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# GitHub Personal Access Token（可选，OAuth 登录后无需配置）
# 未登录用户或 webhook 自动审查时使用。
# 需要 repo 权限（私有仓库）或 public_repo 权限（公开仓库）
# 生成地址：https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_github_token_here

# GitHub OAuth App 凭据（可选，用于用户登录）
# 创建地址：https://github.com/settings/developers → New OAuth App
# Homepage URL: http://localhost:5173
# Authorization callback URL: http://localhost:5173/login/oauth2/code/github
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret

# Redis 连接（可选，默认 localhost:6379）
REDIS_HOST=localhost
REDIS_PORT=6379
